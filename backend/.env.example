# Server
PORT=3000
NODE_ENV=development

# Neon PostgreSQL (neon.tech — free)
DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/aigov?sslmode=require

# Upstash Redis (upstash.com — free)
REDIS_URL=rediss://default:xxx@xxx.upstash.io:6379

# Groq AI (console.groq.com — free, no CC)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx

# JWT (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_ACCESS_SECRET=64_char_hex_generate_with_node_crypto
JWT_REFRESH_SECRET=different_64_char_hex

# Pinata IPFS (pinata.cloud — free)
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET=your_pinata_secret

# Alchemy Sepolia RPC (alchemy.com — free)
ALCHEMY_SEPOLIA_URL=https://eth-sepolia.g.alchemy.com/v2/your_key

# Deployed Contract Addresses (from hardhat deploy)
DAO_TOKEN_ADDRESS=0x...
DAO_GOVERNANCE_ADDRESS=0x...
DAO_TREASURY_ADDRESS=0x...

# Etherscan (for contract verification — optional, free at etherscan.io)
ETHERSCAN_API_KEY=your_etherscan_key

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
